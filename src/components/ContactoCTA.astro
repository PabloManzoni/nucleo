---
---
<section id="contacto" class="alt">
  <div class="wrap">
    <div class="final-cta">
      <div class="reveal">
        <span class="eyebrow">Contacto</span>
        <h2 style="margin-top:14px;">¿Tenés un proyecto en marcha?</h2>
        <p class="lede" style="margin-top:24px;">Contanos en qué etapa está y armamos una propuesta a medida. Te respondemos en menos de 24 horas hábiles.</p>

        <div style="margin-top:48px; display:grid; gap:18px; max-width:380px;">
          <div style="display:grid; grid-template-columns:auto 1fr; gap:14px; align-items:baseline; padding:14px 0; border-top:1px solid var(--line);">
            <span style="font-family:var(--t-mono); font-size:11.5px; color:var(--ink-3); letter-spacing:.08em;">EMAIL</span>
            <a href="mailto:proyectos@nucleo.build" style="font-weight:500;">proyectos@nucleo.build</a>
          </div>
          <div style="display:grid; grid-template-columns:auto 1fr; gap:14px; align-items:baseline; padding:14px 0; border-top:1px solid var(--line);">
            <span style="font-family:var(--t-mono); font-size:11.5px; color:var(--ink-3); letter-spacing:.08em;">TEL</span>
            <span style="font-weight:500;">+598 2 707 1188</span>
          </div>
          <div style="display:grid; grid-template-columns:auto 1fr; gap:14px; align-items:baseline; padding:14px 0; border-top:1px solid var(--line); border-bottom:1px solid var(--line);">
            <span style="font-family:var(--t-mono); font-size:11.5px; color:var(--ink-3); letter-spacing:.08em;">CIUDAD</span>
            <span style="font-weight:500;">Montevideo · Buenos Aires</span>
          </div>
        </div>
      </div>

      <form id="contact-form" class="form reveal" style="background:var(--bg); padding:36px; border:1px solid var(--line); border-radius:6px; align-self:start;">
        <div class="form-grid" style="display:contents;">
          <div class="field">
            <label for="f-nombre">Nombre</label>
            <input id="f-nombre" type="text" placeholder="Nombre y apellido" required />
          </div>
          <div class="field">
            <label for="f-empresa">Empresa</label>
            <input id="f-empresa" type="text" placeholder="Constructora · estudio" required />
          </div>
          <div class="field">
            <label for="f-email">Email</label>
            <input id="f-email" type="email" placeholder="hola@constructora.com" required />
          </div>
          <div class="field">
            <label for="f-tel">Teléfono</label>
            <input id="f-tel" type="tel" placeholder="+598 / +54" />
          </div>
          <div class="field full">
            <label for="f-etapa">Etapa del proyecto</label>
            <select id="f-etapa" required>
              <option value="">Seleccionar etapa</option>
              <option>En planos</option>
              <option>Obra inicial</option>
              <option>Obra avanzada</option>
              <option>Pre-entrega</option>
            </select>
          </div>
          <div class="field full">
            <label for="f-msg">Mensaje (opcional)</label>
            <textarea id="f-msg" placeholder="Contanos brevemente sobre el proyecto"></textarea>
          </div>
          <div class="form-actions full">
            <button type="submit" class="btn btn-primary">Enviar <span class="btn-arrow">→</span></button>
            <span class="note">Te respondemos en menos de 24 hs hábiles.</span>
          </div>
        </div>
        <div class="sent full" style="display:none; text-align:left;">
          <div style="font-family:var(--t-mono); font-size:11.5px; color:var(--accent-2); letter-spacing:.08em;">RECIBIDO</div>
          <h3 style="margin-top:8px;">Gracias. Te respondemos en breve.</h3>
          <p class="muted" style="margin-top:8px;">Vamos a leer tu mensaje y ponernos en contacto en menos de 24 horas hábiles.</p>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const grid = form.querySelector<HTMLElement>('.form-grid');
      const sent = form.querySelector<HTMLElement>('.sent');
      if (grid) grid.style.display = 'none';
      if (sent) sent.style.display = 'block';
    });
  }
</script>
